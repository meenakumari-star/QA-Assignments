{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "DOM"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@tests/*": ["./tests/*"],
      "@pages/*": ["./tests/pages/*"],
      "@utils/*": ["./utils/*"],
      "@data/*": ["./data/*"],
      "@fixtures/*": ["./fixtures/*"],
      "@api/*": ["./api-clients/*"]
    },
    "types": ["node", "@playwright/test"],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "tests/**/*",
    "src/**/*",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test-results",
    "playwright-report"
  ]
}